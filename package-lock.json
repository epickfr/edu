COPY ["package.json", "pnpm-lock.yaml", "./"]
# Install pnpm globally if not already in the base image
RUN npm install -g pnpm@latest
RUN apk add --upgrade --no-cache python3 make g++   # keep if needed for native deps
RUN pnpm install --frozen-lockfile   # or pnpm install if you don't mind updating lockfile
# Then your build/start commands, e.g.
# RUN pnpm build   # if there's a build step
# CMD ["pnpm", "start"]
